Team A edge = (Team A eFG% - Team B eFG%) + (Team B eFG%D - Team A eFG%D)
Team B edge = (Team B eFG% - Team A eFG%) + (Team A eFG%D - Team B eFG%D)

Team A Turnover Edge = (A TOV%D - A TOV%) - (B TOV%D - B TOV%)
Team B Turnover Edge = (B TOV%D - B TOV%) - (A TOV%D - A TOV%)

Team A Rebounding Edge = (A ORB% - B DRB%) - (B ORB% - A DRB%)
Team B Rebounding Edge = (Team B ORB% - Team A DRB%) - (A ORB% - B DRB%)

Team A Free Throw Edge = (A FTr - A FTrD) - (B FTr - B FTrD)
Team B Free Throw Edge = (B FTr - B FTrD) - (A FTr - A FTrD)

Team A Total Edge = 0.4 * A Shooting + 0.25 * A Turnover + 0.2 * A Rebounding + 0.15 * A FT
Team B Total Edge = 0.4 * B Shooting + 0.25 * B Turnover + 0.2 * B Rebounding + 0.15 * B FT
