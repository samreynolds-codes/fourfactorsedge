Team A Shooting Edge: (teamA.efg - teamB.efg) + (teamB.efgd - teamA.efgd)
Team B Shooting Edge: (teamB.efg - teamA.efg) + (teamA.efgd - teamB.efgd)

Team A Turnover Edge: (teamB.tov - teamA.tov) + (teamA.tovd - teamB.tovd)
Team B Turnover Edge: (teamA.tov - teamB.tov) + (teamB.tovd - teamA.tovd)

Team A Rebounding Edge: (teamA.orb - teamB.orb) + (teamA.drb - teamB.drb)
Team B Rebounding Edge: (teamB.orb - teamA.orb) + (teamB.drb - teamA.drb)

Team A Free Throw Edge: (teamA.ftr - teamB.ftr) + (teamB.ftrd - teamA.ftrd)
Team B Free Throw Edge: (teamB.ftr - teamA.ftr) + (teamA.ftrd - teamB.ftrd)
       
Team A Total Edge: (0.4 * edges.shooting.a + 0.25 * edges.turnovers.a + 0.2 * edges.rebounding.a + 0.15 * edges.freeThrow.a)
Team B Total Edge: (0.4 * edges.shooting.b + 0.25 * edges.turnovers.b + 0.2 * edges.rebounding.b + 0.15 * edges.freeThrow.b)
